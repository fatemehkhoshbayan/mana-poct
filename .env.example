# --- Database ---
DATABASE_URL=postgresql+asyncpg://poct:poct@db:5432/poct

# --- LLM via OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-3.7-sonnet
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=MANA POCT QC Assistant

# --- Observability via LangFuse Cloud ---
LANGFUSE_PUBLIC_KEY=                            
LANGFUSE_SECRET_KEY=                           
LANGFUSE_HOST=https://cloud.langfuse.com   

# --- Event-driven Hard Block dispatch ---
# ntfy.sh: free, zero-signup push notification. Pick a unique topic, then open
# https://ntfy.sh/<topic> in a browser (no account/app needed) to watch it live.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
# Kafka: only used if set. Run `docker compose --profile kafka up` then set
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092 (Docker) or localhost:9092 (standalone).
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC=poct.device.hardblock

# --- App ---
DEFAULT_TENANT_ID=demo
LOG_LEVEL=INFO   # set to DEBUG for verbose output

# Comma-separated allowed frontend origin(s) for CORS. In production, set to
# your deployed frontend URL, e.g. https://my-app.vercel.app
CORS_ALLOW_ORIGINS=http://localhost:5173,http://frontend:5173
